{
  "name": "@context9/cli",
  "version": "0.1.0",
  "description": "Agent-oriented context and secret manager backed by db9.",
  "type": "module",
  "bin": {
    "context9": "./dist/cli.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "agents",
    "cli",
    "db9",
    "secrets",
    "worktree"
  ],
  "license": "MIT",
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "get-db9": "^0.6.1",
    "picocolors": "^1.1.1",
    "postgres": "^3.4.8",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
